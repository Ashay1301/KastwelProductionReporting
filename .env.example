MONGODB_URI=mongodb://kastwel-app:<password>@127.0.0.1:27017/kastwel-production?authSource=kastwel-production
JWT_SECRET=change_me_to_a_long_random_string
CORS_ORIGIN=https://your-public-origin-here
NODE_ENV=production
PORT=3001

# Only needed for the one-time `node seed.js` run — remove after seeding.
SEED_ADMIN_PASSWORD=
SEED_WORKER_PASSWORD=
